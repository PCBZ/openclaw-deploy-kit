{
  "gateway": {
    "bind": "lan",
    "auth": {
      "mode": "token"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/meta-llama/llama-3.3-70b-instruct:free",
        "fallbacks": [
          "openrouter/auto"
        ]
      },
      "models": {
        "openrouter/meta-llama/llama-3.3-70b-instruct:free": {"alias": "llama"},
        "openrouter/cognitivecomputations/dolphin-mistral-24b-venice-edition:free": {"alias": "uncensored"},
        "openrouter/google/gemini-2.0-flash-exp:free": {"alias": "gemini"},
        "openrouter/auto": {"alias": "auto"}
      },
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 20000
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "provider": "brave"
      },
      "fetch": {
        "enabled": false
      }
    },
    "deny": ["browser"]
  },
  "plugins": {
    "entries": {
      "openrouter": { "enabled": true },
      "brave": {
        "enabled": true,
        "config": {
          "webSearch": {
            "apiKey": "${BRAVE_API_KEY}"
          }
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "accounts": {
        "default": {
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "dmPolicy": "open",
          "groupPolicy": "open"
        }
      }
    }
  }
}
